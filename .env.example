# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=HIM - Her Intelligent Mate

# App Configuration
APP_NAME=HIM - Her Intelligent Mate
APP_URL=http://localhost/MCA%20PHP/CA2
APP_DEBUG=true
